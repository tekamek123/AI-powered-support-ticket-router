[flake8]
# Match Black's default line length
max-line-length = 88

# Ignore rules that conflict with Black formatter
extend-ignore =
    E203,  # whitespace before ':'  (Black handles this)
    E501,  # line too long          (Black handles this)
    W503,  # line break before binary operator

# Directories to exclude
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    build,
    dist,
    .eggs,
    *.egg-info,
    .mypy_cache,
    .pytest_cache,
    notebooks/

per-file-ignores =
    # Allow unused imports in __init__.py files
    __init__.py: F401
    # Allow assert statements in tests
    tests/*: S101
